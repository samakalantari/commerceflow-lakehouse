networks:
  internal:
    name: ${COMPOSE_PROJECT_NAME}_internal

  traefik_network:
    name: ${TRAEFIK_NETWORK}
    external: true


volumes:
  postgres_data:
  clickhouse_data:
  mongodb_data:
  minio_data:
  spark_logs:
  spark_ivy:
  airflow_logs:
  prometheus_data:
  grafana_data:


x-common-service: &common-service
  restart: unless-stopped
  networks:
    - internal


services:

  #──────────────────────────────────────────────────────────────────────
  # ClickHouse
  #──────────────────────────────────────────────────────────────────────
  clickhouse:
    <<: *common-service
    image: ${CLICKHOUSE_IMAGE}
    ports:
      - "${BIND_IP}:${CLICKHOUSE_HTTP_PORT}:8123"
      - "${BIND_IP}:${CLICKHOUSE_NATIVE_PORT}:9000"
    volumes:
      - clickhouse_data:/var/lib/clickhouse
    environment:
      CLICKHOUSE_USER: ${CLICKHOUSE_USER}
      CLICKHOUSE_PASSWORD: ${CLICKHOUSE_PASSWORD}
      CLICKHOUSE_DB: ${CLICKHOUSE_DB}
    healthcheck:
      test: ["CMD-SHELL", "clickhouse-client --user=$$CLICKHOUSE_USER --password=$$CLICKHOUSE_PASSWORD --query='SELECT 1'"]
      interval: 20s
      timeout: 10s
      retries: 5
    networks:
      - internal
      - traefik_network
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=${TRAEFIK_NETWORK}"
      - "traefik.http.routers.clickhouse.rule=Host(`clickhouse.${DOMAIN_SUFFIX}`)"
      - "traefik.http.routers.clickhouse.entrypoints=websecure"
      - "traefik.http.routers.clickhouse.tls=true"
      - "traefik.http.services.clickhouse.loadbalancer.server.port=8123"

  #──────────────────────────────────────────────────────────────────────
  # PostgreSQL
  #──────────────────────────────────────────────────────────────────────
  postgres:
    <<: *common-service
    image: ${POSTGRES_IMAGE}
    ports:
      - "${BIND_IP}:${POSTGRES_PORT}:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    environment:
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: ${POSTGRES_DB}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $$POSTGRES_USER -d $$POSTGRES_DB"]
      interval: 10s
      timeout: 5s
      retries: 10

  #──────────────────────────────────────────────────────────────────────
  # MongoDB
  #──────────────────────────────────────────────────────────────────────
  mongodb:
    <<: *common-service
    image: ${MONGODB_IMAGE}
    ports:
      - "${BIND_IP}:${MONGO_PORT}:27017"
    volumes:
      - mongodb_data:/data/db
    environment:
      MONGO_INITDB_ROOT_USERNAME: ${MONGO_INITDB_ROOT_USERNAME}
      MONGO_INITDB_ROOT_PASSWORD: ${MONGO_INITDB_ROOT_PASSWORD}

  #──────────────────────────────────────────────────────────────────────
  # MinIO
  #──────────────────────────────────────────────────────────────────────
  minio:
    <<: *common-service
    image: ${MINIO_IMAGE}
    ports:
      - "${BIND_IP}:${MINIO_CONSOLE_PORT}:9001"
    volumes:
      - minio_data:/data
    environment:
      MINIO_ROOT_USER: ${MINIO_ROOT_USER}
      MINIO_ROOT_PASSWORD: ${MINIO_ROOT_PASSWORD}
    command: server /data --console-address ":9001"
    networks:
      - internal
      - traefik_network
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=${TRAEFIK_NETWORK}"

      - "traefik.http.routers.minio-api.rule=Host(`minio-api.${DOMAIN_SUFFIX}`)"
      - "traefik.http.routers.minio-api.entrypoints=websecure"
      - "traefik.http.routers.minio-api.tls=true"
      - "traefik.http.routers.minio-api.service=minio-api"
      - "traefik.http.services.minio-api.loadbalancer.server.port=9000"

      - "traefik.http.routers.minio-console.rule=Host(`minio.${DOMAIN_SUFFIX}`)"
      - "traefik.http.routers.minio-console.entrypoints=websecure"
      - "traefik.http.routers.minio-console.tls=true"
      - "traefik.http.routers.minio-console.service=minio-console"
      - "traefik.http.services.minio-console.loadbalancer.server.port=9001"

  #──────────────────────────────────────────────────────────────────────
  # Spark
  #──────────────────────────────────────────────────────────────────────
  spark-master:
    <<: *common-service
    image: ${SPARK_IMAGE}
    environment:
      SPARK_MODE: master
      SPARK_RPC_AUTHENTICATION_ENABLED: "no"
      SPARK_RPC_ENCRYPTION_ENABLED: "no"
      SPARK_LOCAL_STORAGE_ENCRYPTION_ENABLED: "no"
      SPARK_SSL_ENABLED: "no"
      HOME: /tmp
    volumes:
      - spark_logs:/opt/spark/logs
      - spark_ivy:/tmp/.ivy2
      - ./spark-apps:/opt/spark-apps
    networks:
      - internal
      - traefik_network
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=${TRAEFIK_NETWORK}"
      - "traefik.http.routers.spark-master.rule=Host(`spark.${DOMAIN_SUFFIX}`)"
      - "traefik.http.routers.spark-master.entrypoints=websecure"
      - "traefik.http.routers.spark-master.tls=true"
      - "traefik.http.services.spark-master.loadbalancer.server.port=8080"

  spark-worker:
    <<: *common-service
    image: ${SPARK_IMAGE}
    depends_on:
      - spark-master
    environment:
      SPARK_MODE: worker
      SPARK_MASTER_URL: spark://spark-master:7077
      SPARK_WORKER_MEMORY: ${SPARK_WORKER_MEMORY}
      SPARK_WORKER_CORES: ${SPARK_WORKER_CORES}
      SPARK_RPC_AUTHENTICATION_ENABLED: "no"
      SPARK_RPC_ENCRYPTION_ENABLED: "no"
      SPARK_LOCAL_STORAGE_ENCRYPTION_ENABLED: "no"
      SPARK_SSL_ENABLED: "no"
      HOME: /tmp
    volumes:
      - spark_logs:/opt/spark/logs
      - spark_ivy:/tmp/.ivy2
      - ./spark-apps:/opt/spark-apps

  #──────────────────────────────────────────────────────────────────────
  # Airflow
  #──────────────────────────────────────────────────────────────────────
  airflow-init:
    image: ${AIRFLOW_IMAGE}
    user: "${AIRFLOW_UID}:0"
    networks:
      - internal
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      AIRFLOW__CORE__EXECUTOR: LocalExecutor
      AIRFLOW__DATABASE__SQL_ALCHEMY_CONN: postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
      AIRFLOW__CORE__FERNET_KEY: ${AIRFLOW_FERNET_KEY}
      AIRFLOW__CORE__LOAD_EXAMPLES: "false"
    volumes:
      - ./airflow/dags:/opt/airflow/dags
      - airflow_logs:/opt/airflow/logs
      - ./airflow/plugins:/opt/airflow/plugins
    entrypoint: /bin/bash
    command:
      - -c
      - |
        airflow db migrate
        airflow users create \
          --username ${AIRFLOW_ADMIN_USER} \
          --password ${AIRFLOW_ADMIN_PASSWORD} \
          --firstname Admin \
          --lastname User \
          --role Admin \
          --email ${AIRFLOW_ADMIN_EMAIL} || true
    restart: "no"

  airflow-webserver:
    image: ${AIRFLOW_IMAGE}
    user: "${AIRFLOW_UID}:0"
    restart: unless-stopped
    networks:
      - internal
      - traefik_network
    depends_on:
      postgres:
        condition: service_healthy
      airflow-init:
        condition: service_completed_successfully
      statsd-exporter:
        condition: service_started
    environment:
      AIRFLOW__CORE__EXECUTOR: LocalExecutor
      AIRFLOW__DATABASE__SQL_ALCHEMY_CONN: postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
      AIRFLOW__CORE__FERNET_KEY: ${AIRFLOW_FERNET_KEY}
      AIRFLOW__CORE__LOAD_EXAMPLES: "false"
      AIRFLOW__WEBSERVER__EXPOSE_CONFIG: "true"

      AIRFLOW__METRICS__STATSD_ON: "true"
      AIRFLOW__METRICS__STATSD_HOST: statsd-exporter
      AIRFLOW__METRICS__STATSD_PORT: 9125
      AIRFLOW__METRICS__STATSD_PREFIX: airflow
    volumes:
      - ./airflow/dags:/opt/airflow/dags
      - airflow_logs:/opt/airflow/logs
      - ./airflow/plugins:/opt/airflow/plugins
      - ./spark-apps:/opt/spark-apps
    command: webserver
    healthcheck:
      test: ["CMD", "curl", "--fail", "http://localhost:8080/health"]
      interval: 30s
      timeout: 10s
      retries: 5
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=${TRAEFIK_NETWORK}"
      - "traefik.http.routers.airflow.rule=Host(`airflow.${DOMAIN_SUFFIX}`)"
      - "traefik.http.routers.airflow.entrypoints=websecure"
      - "traefik.http.routers.airflow.tls=true"
      - "traefik.http.services.airflow.loadbalancer.server.port=8080"

  airflow-scheduler:
    image: ${AIRFLOW_IMAGE}
    user: "${AIRFLOW_UID}:0"
    restart: unless-stopped
    networks:
      - internal
    depends_on:
      postgres:
        condition: service_healthy
      airflow-init:
        condition: service_completed_successfully
      statsd-exporter:
        condition: service_started
    environment:
      AIRFLOW__CORE__EXECUTOR: LocalExecutor
      AIRFLOW__DATABASE__SQL_ALCHEMY_CONN: postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
      AIRFLOW__CORE__FERNET_KEY: ${AIRFLOW_FERNET_KEY}
      AIRFLOW__CORE__LOAD_EXAMPLES: "false"

      AIRFLOW__METRICS__STATSD_ON: "true"
      AIRFLOW__METRICS__STATSD_HOST: statsd-exporter
      AIRFLOW__METRICS__STATSD_PORT: 9125
      AIRFLOW__METRICS__STATSD_PREFIX: airflow
    volumes:
      - ./airflow/dags:/opt/airflow/dags
      - airflow_logs:/opt/airflow/logs
      - ./airflow/plugins:/opt/airflow/plugins
      - ./spark-apps:/opt/spark-apps
    command: scheduler

  #──────────────────────────────────────────────────────────────────────
  # Metabase
  #──────────────────────────────────────────────────────────────────────
  metabase:
    <<: *common-service
    image: ${METABASE_IMAGE}
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      MB_DB_TYPE: postgres
      MB_DB_DBNAME: ${POSTGRES_DB}
      MB_DB_PORT: 5432
      MB_DB_USER: ${POSTGRES_USER}
      MB_DB_PASS: ${POSTGRES_PASSWORD}
      MB_DB_HOST: postgres
    networks:
      - internal
      - traefik_network
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=${TRAEFIK_NETWORK}"
      - "traefik.http.routers.metabase.rule=Host(`metabase.${DOMAIN_SUFFIX}`)"
      - "traefik.http.routers.metabase.entrypoints=websecure"
      - "traefik.http.routers.metabase.tls=true"
      - "traefik.http.services.metabase.loadbalancer.server.port=3000"

  #──────────────────────────────────────────────────────────────────────
  # Monitoring
  #──────────────────────────────────────────────────────────────────────
  statsd-exporter:
    <<: *common-service
    image: ${STATSD_EXPORTER_IMAGE}
    ports:
      - "${BIND_IP}:${STATSD_TCP_PORT}:9102"
      - "${BIND_IP}:${STATSD_UDP_PORT}:9125/udp"

  prometheus:
    <<: *common-service
    image: ${PROMETHEUS_IMAGE}
    depends_on:
      - statsd-exporter
    ports:
      - "${BIND_IP}:9090:9090"
    volumes:
      - ./prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus_data:/prometheus
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.path=/prometheus"
      - "--storage.tsdb.retention.time=${PROMETHEUS_RETENTION}"
    networks:
      - internal
      - traefik_network
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=${TRAEFIK_NETWORK}"
      - "traefik.http.routers.prometheus.rule=Host(`prometheus.${DOMAIN_SUFFIX}`)"
      - "traefik.http.routers.prometheus.entrypoints=websecure"
      - "traefik.http.routers.prometheus.tls=true"
      - "traefik.http.services.prometheus.loadbalancer.server.port=9090"

  grafana:
    <<: *common-service
    image: ${GRAFANA_IMAGE}
    depends_on:
      - prometheus
    volumes:
      - grafana_data:/var/lib/grafana
    environment:
      GF_SECURITY_ADMIN_USER: ${GRAFANA_ADMIN_USER}
      GF_SECURITY_ADMIN_PASSWORD: ${GRAFANA_ADMIN_PASSWORD}
    networks:
      - internal
      - traefik_network
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=${TRAEFIK_NETWORK}"
      - "traefik.http.routers.grafana.rule=Host(`grafana.${DOMAIN_SUFFIX}`)"
      - "traefik.http.routers.grafana.entrypoints=websecure"
      - "traefik.http.routers.grafana.tls=true"
      - "traefik.http.services.grafana.loadbalancer.server.port=3000"
